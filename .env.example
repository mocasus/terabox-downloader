# Terabox Downloader Bot — Environment Configuration
# Copy to .env and fill in your values

# ═══════════════════════════════════════════════════
# 🤖 BOT
# ═══════════════════════════════════════════════════
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
ADMIN_IDS=123456789,987654321

# ═══════════════════════════════════════════════════
# 👑 VIP (set VIP_ENABLED=true to require payment)
# ═══════════════════════════════════════════════════
VIP_ENABLED=false
VIP_PRICE=15000
VIP_DURATION_DAYS=30
VIP_TRIAL_ENABLED=false
VIP_TRIAL_DOWNLOADS=3

# ═══════════════════════════════════════════════════
# 💳 KlikQRIS Payment Gateway
# ═══════════════════════════════════════════════════
KLIKQRIS_API_KEY=your_api_key_here
KLIKQRIS_MERCHANT_ID=your_merchant_id_here
KLIKQRIS_WEBHOOK_SECRET=change_this_random_string
KLIKQRIS_SANDBOX=false
# Webhook server for KlikQRIS callbacks
WEBHOOK_HOST=https://your-domain.com
WEBHOOK_PORT=8000

# ═══════════════════════════════════════════════════
# ⬇️ DOWNLOAD
# ═══════════════════════════════════════════════════
MAX_FILE_SIZE_MB=50
CONCURRENT_DOWNLOADS=3
DOWNLOAD_DIR=/tmp/terabox

# ═══════════════════════════════════════════════════
# 🗄️ DATABASE
# ═══════════════════════════════════════════════════
DATABASE_URL=sqlite:///data.db
